{
  "name": "askpplx",
  "version": "1.0.0",
  "description": "Minimal Unix-style CLI for querying Perplexity Sonar API.",
  "keywords": [],
  "license": "MIT",
  "author": "Łukasz Jerciński",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Jercik/askpplx.git"
  },
  "bin": {
    "askpplx": "bin/askpplx"
  },
  "files": [
    "bin/",
    "dist/",
    "README.md",
    "LICENSE"
  ],
  "type": "module",
  "scripts": {
    "prepack": "pnpm run rebuild",
    "prepare": "git config core.hooksPath .githooks",
    "build": "tsgo -p tsconfig.app.json && cp -r src/prompts dist/",
    "clean": "rm -rf dist *.tsbuildinfo",
    "format": "oxfmt .",
    "format:check": "oxfmt --check .",
    "fta": "fta-check",
    "knip": "knip",
    "lint": "oxlint --deny-warnings --report-unused-disable-directives .",
    "rebuild": "pnpm run clean && pnpm run build",
    "start": "pnpm -s run rebuild && node --env-file=.env bin/askpplx",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "typecheck": "tsgo -b --noEmit"
  },
  "dependencies": {
    "@ai-sdk/perplexity": "^3.0.29",
    "@commander-js/extra-typings": "^14.0.0",
    "ai": "^6.0.168",
    "commander": "^14.0.3",
    "conf": "^15.1.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@total-typescript/ts-reset": "^0.6.1",
    "@types/node": "^25.6.0",
    "@typescript/native-preview": "beta",
    "@vitest/coverage-v8": "^4.1.5",
    "fta-check": "^1.5.2",
    "fta-cli": "^3.0.0",
    "knip": "^6.6.3",
    "oxfmt": "^0.46.0",
    "oxlint": "^1.61.0",
    "oxlint-config-j4k": "^2.3.0",
    "oxlint-tsgolint": "^0.22.0",
    "semantic-release": "^25.0.3",
    "vitest": "^4.1.5"
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "packageManager": "pnpm@10.33.0",
  "pnpm": {
    "overrides": {
      "@typescript/native-preview": "7.0.0-dev.20260425.1"
    }
  }
}
