{
  "name": "askpplx",
  "version": "1.0.0",
  "description": "Minimal Unix-style CLI for querying Perplexity Sonar API.",
  "keywords": [],
  "license": "MIT",
  "author": "Łukasz Jerciński",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Jercik/askpplx.git"
  },
  "bin": {
    "askpplx": "bin/askpplx"
  },
  "files": [
    "bin/",
    "dist/",
    "README.md",
    "LICENSE"
  ],
  "type": "module",
  "publishConfig": {
    "registry": "https://registry.npmjs.org/"
  },
  "scripts": {
    "build": "tsc -p tsconfig.app.json && cp -r src/prompts dist/",
    "clean": "rm -rf dist *.tsbuildinfo",
    "format": "oxfmt --config .oxfmtrc.json .",
    "format:check": "oxfmt --check --config .oxfmtrc.json .",
    "fta": "fta-check",
    "knip": "knip",
    "lint": "oxlint --deny-warnings --report-unused-disable-directives .",
    "prepack": "pnpm run rebuild",
    "prepare": "if git rev-parse --is-inside-work-tree >/dev/null 2>&1; then git config core.hooksPath .githooks; fi",
    "rebuild": "pnpm run clean && pnpm run build",
    "start": "pnpm -s run rebuild && node --env-file=.env bin/askpplx",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "typecheck": "tsc -b --noEmit"
  },
  "dependencies": {
    "@ai-sdk/perplexity": "^3.0.42",
    "@commander-js/extra-typings": "^15.0.0",
    "ai": "^6.0.198",
    "commander": "^15.0.0",
    "conf": "^15.1.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@j4k/oxlint-config": "^2.11.0",
    "@total-typescript/ts-reset": "^0.6.1",
    "@types/node": "^25.9.2",
    "@vitest/coverage-v8": "^4.1.8",
    "fta-check": "^1.5.2",
    "fta-cli": "^3.0.0",
    "knip": "^6.16.1",
    "oxfmt": "^0.57.0",
    "oxlint": "^1.72.0",
    "oxlint-tsgolint": "^0.23.0",
    "semantic-release": "^25.0.3",
    "typescript": "^7.0.2",
    "vitest": "^4.1.8"
  },
  "engines": {
    "node": ">=24.2.0"
  },
  "packageManager": "pnpm@11.8.0"
}
